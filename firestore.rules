rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isProfessor() {
      return request.auth != null
        && request.auth.token.email == 'pro.david.hebert@gmail.com'
        && request.auth.token.email_verified == true
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    function validCourse(data) {
      return data.keys().hasOnly([
          'id', 'title', 'slug', 'chapterNumber', 'level', 'blocks',
          'slideCount', 'status', 'manualOrder', 'createdAt', 'updatedAt'
        ])
        && data.id is string
        && data.title is string && data.title.size() > 0 && data.title.size() <= 120
        && data.slug is string
        && data.chapterNumber is string && data.chapterNumber.size() <= 20
        && data.level in ['6', '4']
        && data.blocks is list && data.blocks.size() <= 200
        && data.slideCount is int && data.slideCount >= 1 && data.slideCount <= 200
        && data.status in ['draft', 'published']
        && (data.manualOrder == null || (data.manualOrder is int && data.manualOrder >= 0 && data.manualOrder <= 999))
        && data.createdAt is string
        && data.updatedAt is string;
    }

    function validLegacyCourse(data) {
      return data.keys().hasOnly([
          'id', 'title', 'slug', 'level', 'category', 'summary', 'content',
          'status', 'sortOrder', 'createdAt', 'updatedAt'
        ])
        && data.id is string
        && data.title is string && data.title.size() > 0 && data.title.size() <= 120
        && data.level in ['6', '4']
        && data.content is string && data.content.size() <= 200000
        && data.status in ['draft', 'published'];
    }

    function validImage(data) {
      return data.keys().hasOnly([
          'id', 'courseId', 'dataUrl', 'alt', 'published', 'createdAt'
        ])
        && data.id is string
        && data.courseId is string
        && data.dataUrl is string && data.dataUrl.size() > 0 && data.dataUrl.size() <= 750000
        && data.alt is string && data.alt.size() <= 160
        && data.published is bool
        && data.createdAt is string;
    }

    match /courses/{courseId} {
      allow read: if isProfessor();
      allow create, update: if isProfessor()
        && request.resource.data.id == courseId
        && (validCourse(request.resource.data) || validLegacyCourse(request.resource.data));
      allow delete: if isProfessor();
    }

    match /catalogs/{level} {
      allow read: if level in ['6', '4'];
      allow write: if isProfessor()
        && level in ['6', '4']
        && request.resource.data.level == level
        && request.resource.data.courses is list
        && request.resource.data.courses.size() <= 200;
    }

    match /publishedCourses/{courseId} {
      allow read: if true;
      allow create, update: if isProfessor()
        && request.resource.data.id == courseId
        && request.resource.data.status == 'published'
        && (validCourse(request.resource.data) || validLegacyCourse(request.resource.data));
      allow delete: if isProfessor();
    }

    match /courseImages/{imageId} {
      allow read: if isProfessor() || resource.data.published == true;
      allow create, update: if isProfessor()
        && request.resource.data.id == imageId
        && validImage(request.resource.data);
      allow delete: if isProfessor();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
